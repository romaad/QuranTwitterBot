# X (Twitter) API v2 credentials
# Obtain from https://developer.twitter.com/en/portal/dashboard
API_KEY=your_api_key
API_SECRET=your_api_secret
ACCESS_TOKEN=your_access_token
ACCESS_TOKEN_SECRET=your_access_token_secret

# Optional: Pexels API key for auto-fetching background nature videos.
# Obtain a free key at https://www.pexels.com/api/
# When set, the bot fetches a portrait nature video from Pexels automatically;
# otherwise config.nature_video_path (a local file) is used as the background.
# PEXELS_API_KEY=your_pexels_api_key

# Optional: override the SQLite DB path (default: data/quran_bot.db)
# DB_PATH=data/quran_bot.db
